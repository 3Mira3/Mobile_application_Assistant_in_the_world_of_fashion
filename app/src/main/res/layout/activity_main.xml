<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toTopOf="@id/custom_bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navGraph="@navigation/nav_graph" />

    <!-- Custom bottom navigation bar — no 5-item limit -->
    <LinearLayout
        android:id="@+id/custom_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="62dp"
        android:background="?android:attr/windowBackground"
        android:elevation="8dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Tab: Home -->
        <LinearLayout
            android:id="@+id/tab_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">
            <ImageView
                android:id="@+id/tab_home_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_today"
                app:tint="@color/text_secondary" />
            <TextView
                android:id="@+id/tab_home_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_home"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Tab: History -->
        <LinearLayout
            android:id="@+id/tab_history"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">
            <ImageView
                android:id="@+id/tab_history_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="@color/text_secondary" />
            <TextView
                android:id="@+id/tab_history_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_history"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Tab: Mixer -->
        <LinearLayout
            android:id="@+id/tab_mixer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">
            <ImageView
                android:id="@+id/tab_mixer_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_view"
                app:tint="@color/text_secondary" />
            <TextView
                android:id="@+id/tab_mixer_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_mixer"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Tab: Stylists -->
        <LinearLayout
            android:id="@+id/tab_stylists"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">
            <ImageView
                android:id="@+id/tab_stylists_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/text_secondary" />
            <TextView
                android:id="@+id/tab_stylists_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_stylists"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Tab: Colors -->
        <LinearLayout
            android:id="@+id/tab_colors"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">
            <ImageView
                android:id="@+id/tab_colors_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="@color/text_secondary" />
            <TextView
                android:id="@+id/tab_colors_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_colors"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Tab: Profile -->
        <LinearLayout
            android:id="@+id/tab_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">
            <ImageView
                android:id="@+id/tab_profile_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="@color/text_secondary" />
            <TextView
                android:id="@+id/tab_profile_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_profile"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

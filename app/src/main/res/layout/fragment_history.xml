<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.fragments.HistoryFragment">

    <!-- Main Content Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_fashion_gradient"
        android:animateLayoutChanges="true">

        <!-- Edge Hover Detector -->
        <View
            android:id="@+id/view_edge_detector"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Header with Title and Menu Icon -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:elevation="0dp"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:layout_marginTop="24dp"
                app:contentInsetStart="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp">

                    <ImageView
                        android:id="@+id/image_menu"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="@color/primary"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"/>

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="16dp"
                            android:layout_gravity="bottom"
                            android:layout_marginBottom="4dp"
                            android:background="@drawable/bg_title_accent" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/history_title"
                            android:textColor="@color/primary"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/comic_sans"
                            android:shadowColor="#40000000"
                            android:shadowDx="2"
                            android:shadowDy="4"
                            android:shadowRadius="3"
                            android:letterSpacing="0.02" />
                    </FrameLayout>
                    <ImageView
                        android:id="@+id/image_parts_list"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="@color/white"
                        android:padding="10dp"
                        android:rotation="90"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_title_accent" />
                </LinearLayout>
            </androidx.appcompat.widget.Toolbar>
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Top Navigation (Clothing Parts) with Fixed Toggle -->
        <LinearLayout
            android:id="@+id/layout_parts_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            app:layout_constraintTop_toBottomOf="@id/app_bar">

            <androidx.cardview.widget.CardView
                android:id="@+id/image_parts_list_fixed"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/primary">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="@color/white"
                    android:padding="12dp"
                    android:rotation="90" />
            </androidx.cardview.widget.CardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_parts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp"
                android:clipToPadding="false"
                android:layoutAnimation="@anim/layout_animation_fall_down"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_part" />
        </LinearLayout>

        <!-- Content Area (Full Outfits) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_outfits"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:padding="8dp"
            android:clipToPadding="false"
            android:layout_marginTop="4dp"
            android:layoutAnimation="@anim/layout_animation_fall_down"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_parts_nav"
            tools:listitem="@layout/item_fashion_look" />

        <!-- Vertical Parts Overlay (Hidden by default) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_parts_overlay"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="8dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@color/overlay_background"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_parts_nav">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_parts_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_part" />
        </androidx.cardview.widget.CardView>

        <!-- Scroll to Top Button (Hidden by default) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_scroll_up"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:src="@android:drawable/arrow_up_float"
            android:visibility="gone"
            app:fabSize="mini"
            app:backgroundTint="@color/primary"
            app:tint="@color/white"
            android:alpha="0.7"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Side Menu (Centuries) -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@drawable/bg_sidebar_gradient">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/bg_sidebar_gradient"
            android:paddingTop="56dp"
            android:animateLayoutChanges="true">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="24dp">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="18dp"
                    android:layout_gravity="bottom"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/bg_title_accent" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/history_choose_epoch"
                    android:textColor="@color/primary"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/comic_sans"
                    android:shadowColor="#40000000"
                    android:shadowDx="2"
                    android:shadowDy="4"
                    android:shadowRadius="3" />
            </FrameLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_centuries"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="16dp"
                android:clipToPadding="false"
                android:layoutAnimation="@anim/layout_animation_fall_down" />
        </LinearLayout>
    </com.google.android.material.navigation.NavigationView>



</androidx.drawerlayout.widget.DrawerLayout>

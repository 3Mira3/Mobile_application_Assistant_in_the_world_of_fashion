<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_fashion_gradient">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mixer_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/text_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/comic_sans"
                android:text="@string/mixer_title"
                android:textColor="@color/primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- ===== GEMINI CHAT BANNER ЗАКОМЕНТОВАНО =====
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_gemini_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/secondary"
                app:cardBackgroundColor="#E6FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/comic_sans"
                        android:text="@string/chat_banner_title"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/comic_sans"
                        android:text="@string/chat_banner_desc"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_start_ai_chat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="@color/primary"
                        android:text="@string/chat_banner_btn"
                        android:textColor="@color/white"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            ===== -->

            <!-- Upper Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/comic_sans"
                android:text="@string/mixer_upload_upper"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_upper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:minHeight="120dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@android:layout/simple_list_item_1" />

            <Button
                android:id="@+id/btn_add_upper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:backgroundTint="@color/primary"
                android:text="@string/mixer_add_upper"
                android:textColor="@color/white" />

            <!-- Lower Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/comic_sans"
                android:text="@string/mixer_upload_lower"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_lower"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:minHeight="120dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@android:layout/simple_list_item_1" />

            <Button
                android:id="@+id/btn_add_lower"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:backgroundTint="@color/primary"
                android:text="@string/mixer_add_lower"
                android:textColor="@color/white" />

            <!-- Action Button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_mix_card"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="32dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/primary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:fontFamily="@font/comic_sans"
                        android:text="@string/mixer_generate"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Mirror Neon Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:background="@drawable/divider_mirror_neon" />

            <!-- Smart Filters Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="@color/surface">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mixer_smart_params"
                        android:textColor="@color/primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/comic_sans"
                        android:drawablePadding="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mixer_your_style"
                        android:layout_marginTop="20dp"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/comic_sans" />
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupGender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true">
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipFemale"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="@string/mixer_gender_female" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMale"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mixer_gender_male" />
                    </com.google.android.material.chip.ChipGroup>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mixer_season"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/comic_sans" />
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupSeason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true">
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipWinter"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mixer_winter" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSpring"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mixer_spring" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSummer"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mixer_summer" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipAutumn"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mixer_autumn" />
                    </com.google.android.material.chip.ChipGroup>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mixer_destination"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/comic_sans" />
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupDestination"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true">
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipWork"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mixer_work" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipParty"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mixer_party" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipWalk"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mixer_walk" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipGym"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mixer_gym" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMeeting"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mixer_meeting" />
                    </com.google.android.material.chip.ChipGroup>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mixer_mood"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/comic_sans" />
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupMood"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true">
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMoodGood"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mixer_mood_good" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMoodBad"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mixer_mood_bad" />
                    </com.google.android.material.chip.ChipGroup>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSmartMix"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="24dp"
                        android:backgroundTint="@color/primary"
                        app:cornerRadius="20dp"
                        android:fontFamily="@font/comic_sans"
                        android:text="@string/mixer_smart_btn"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:elevation="6dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Chat Widget -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_chat_widget"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="90dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:cardCornerRadius="30dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:strokeWidth="0dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@android:drawable/stat_notify_chat"
            app:tint="@color/white" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Full-screen Chat Overlay -->
    <androidx.drawerlayout.widget.DrawerLayout
        android:id="@+id/chat_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FAFAFA"
        android:visibility="gone"
        android:fitsSystemWindows="true"
        android:clickable="true"
        android:focusable="true">

        <!-- Main Chat Area (ConstraintLayout) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/chat_header"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/primary"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Hamburger Menu Button -->
                <ImageView
                    android:id="@+id/btn_chat_menu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="@color/white"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:contentDescription="Chat History Menu" />

                <ImageView
                    android:id="@+id/btn_chat_minimize"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="@color/white"
                    app:layout_constraintStart_toEndOf="@id/btn_chat_menu"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:contentDescription="Minimize Chat" />

                <ImageView
                    android:id="@+id/btn_chat_close"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="@color/white"
                    app:layout_constraintStart_toEndOf="@id/btn_chat_minimize"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:contentDescription="Close Chat" />

                <TextView
                    android:id="@+id/tv_chat_header_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/comic_sans"
                    android:text="@string/chat_header_title"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/btn_chat_close"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Messages List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_chat_messages"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clipToPadding="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/chat_header"
                app:layout_constraintBottom_toTopOf="@id/chat_input_bar" />

            <!-- Input Bar -->
            <LinearLayout
                android:id="@+id/chat_input_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:background="@color/white"
                android:elevation="8dp"
                app:layout_constraintBottom_toBottomOf="parent">

                <EditText
                    android:id="@+id/et_chat_input"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chat_input"
                    android:hint="@string/chat_input_hint"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#9E9E9E"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="15sp"
                    android:fontFamily="@font/comic_sans"
                    android:inputType="textCapSentences"
                    android:maxLines="4" />

                <ImageButton
                    android:id="@+id/btn_chat_send"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="@color/primary"
                    android:contentDescription="Send Message" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Sidebar Navigation Drawer (Left Panel) -->
        <LinearLayout
            android:id="@+id/chat_sidebar"
            android:layout_width="280dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:background="@drawable/bg_sidebar_gradient"
            android:orientation="vertical"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/comic_sans"
                android:text="@string/chat_history_title"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- New Chat Button inside Drawer -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_chat_new"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/primary"
                android:text="@string/chat_new_chat"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="@font/comic_sans"
                app:cornerRadius="10dp"
                app:icon="@android:drawable/ic_menu_add"
                app:iconTint="@color/white" />

            <!-- RecyclerView for saved chats -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_chat_history"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_chat_history" />

        </LinearLayout>

    </androidx.drawerlayout.widget.DrawerLayout>

    <!-- Overlay for Result / AI Thinking -->
    <FrameLayout
        android:id="@+id/overlay_ai"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ProgressBar
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminateTint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/comic_sans"
                android:text="@string/mixer_ai_analyzing"
                android:textColor="@color/white"
                android:textSize="18sp" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>


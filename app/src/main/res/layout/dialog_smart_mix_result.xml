<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal"
        android:background="@drawable/bg_neon_frame">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/smart_result_ready"
            android:textColor="@color/primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/comic_sans"
            android:layout_marginBottom="16dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="400dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="16dp">
            <ImageView
                android:id="@+id/iv_smart_result"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/look_cafe" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_smart_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/smart_result_location_placeholder"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/comic_sans"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_smart_mood_msg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/smart_result_mood_placeholder"
            android:textSize="18sp"
            android:textStyle="bold|italic"
            android:textColor="@color/accent"
            android:gravity="center"
            android:fontFamily="@font/comic_sans"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tv_smart_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/smart_result_details_placeholder"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:fontFamily="@font/comic_sans"
            android:layout_marginBottom="20dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

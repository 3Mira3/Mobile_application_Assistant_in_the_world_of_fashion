    <!-- Looks -->
    <string name="look_1_title">Ancient Egyptian Kalasiris</string>
    <string name="look_1_desc">Classic tight-fitting sundress with straps.</string>
    <string name="look_1_full">The basis of the female wardrobe of the New Kingdom. It was made from a rectangular linen cloth wrapped around the body.</string>
    
    <string name="look_2_title">Ancient Greek Peplos</string>
    <string name="look_2_desc">Heavy wool garment fixed with fibulae.</string>
    <string name="look_2_full">Archaic Greek clothing. A large rectangle of wool folded in half and belted.</string>

    <string name="look_3_title">Roman Stola</string>
    <string name="look_3_desc">Symbolic attire of a Roman matron.</string>
    <string name="look_3_full">Mandatory clothing for married Roman citizens. It had a wide border (institia).</string>

    <string name="look_4_title">Byzantine Dalmatic</string>
    <string name="look_4_desc">Luxurious tunic with wide sleeves.</string>
    <string name="look_4_full">Byzantine fashion combined the Roman tunic with Eastern luxury. The Dalmatic was sewn from heavy silk.</string>

    <string name="look_5_title">Medieval Houppelande</string>
    <string name="look_5_desc">Voluminous ceremonial dress with a high collar.</string>
    <string name="look_5_full">The pinnacle of 14th-15th century fashion. Required a huge amount of expensive fabric.</string>

    <string name="look_6_title">Egyptian Shendyt</string>
    <string name="look_6_desc">Men\'s loincloth made of pleated linen.</string>
    <string name="look_6_full">The shendyt was a key element of male costume in Ancient Egypt.</string>

    <string name="look_7_title">Persian Anaxyrides</string>
    <string name="look_7_desc">Eastern-style trousers for horse riding.</string>
    <string name="look_7_full">On Greek vases, Persians are depicted in narrow patterned trousers — anaxyrides.</string>

    <string name="look_8_title">Braccae</string>
    <string name="look_8_desc">Gallic and Germanic legionary trousers.</string>
    <string name="look_8_full">Romans initially despised trousers but appreciated their protection during wars in the north.</string>

    <string name="look_9_title">Hose (14th Century)</string>
    <string name="look_9_desc">Separate stocking-trousers that tightly fitted the legs.</string>
    <string name="look_9_full">In the High Middle Ages, men wore hose — two separate legs.</string>

    <string name="look_10_title">Medieval Braies</string>
    <string name="look_10_desc">Under-trousers made of white linen.</string>
    <string name="look_10_full">Braies were the prototype of modern underwear. They had a drawstring for a belt.</string>

